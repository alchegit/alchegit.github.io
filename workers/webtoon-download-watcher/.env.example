# Runs on the remote browser server.
# It watches manually downloaded images and uploads them to the Oracle API.

WEBTOON_API_BASE_URL=https://your-api.example.com
WEBTOON_WORKER_TOKEN=replace_with_long_random_worker_token
DOWNLOAD_DIR=/home/webtoonbrowser/Downloads
UPLOADED_DIR=/home/webtoonbrowser/Downloads/uploaded
STATE_FILE=/home/webtoonbrowser/.webtoon-download-watcher-state.json
POLL_INTERVAL_SECONDS=5
MAX_UPLOAD_MB=12

# Optional metadata attached to uploaded files.
PROJECT_ID=
PANEL_ID=
JOB_ID=
