# Server
HOST=127.0.0.1
PORT=8088
PUBLIC_BASE_URL=https://your-api.example.com
ALLOWED_ORIGINS=https://alchegit.github.io,http://127.0.0.1:8787

# Browser auth. Supabase is used only as the Google OAuth identity provider.
SUPABASE_URL=https://anjbgbqkeukllsdxgckv.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace_me
# Optional. When set, banning a member also bans the Supabase Auth account.
SUPABASE_SERVICE_ROLE_KEY=
ADMIN_GOOGLE_EMAIL=wlgnsl14@gmail.com
ADMIN_ONLY_CREATION=true

# Server-to-server auth. Use long random values on the server only.
WEBTOON_WORKER_TOKEN=replace_with_long_random_worker_token
ADMIN_USER_ID=admin
ADMIN_DISPLAY_NAME=NeoKIM
SECURITY_HASH_SECRET=replace_with_another_long_random_secret
SECURITY_RETENTION_DAYS=30
# Optional private JSON file. Never place this file in the public web root.
WEBTOON_ADMIN_PLAN_FILE=/etc/neokim/webtoon-plan.json

# Oracle 19c on EENTA_REPO3. Keep real values only in the server .env.
ORACLE_USER=ORAHOON
ORACLE_PASSWORD=replace_with_oracle_password
ORACLE_CONNECT_STRING=host.example.com:1521/PDB1
ORACLE_POOL_MIN=1
ORACLE_POOL_MAX=4

# Files
WEBTOON_ASSET_DIR=/var/lib/neokim-webtoon/assets
WEBTOON_TMP_DIR=/var/lib/neokim-webtoon/tmp
MAX_UPLOAD_MB=12
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_PER_WINDOW=60
CREATION_RATE_LIMIT_PER_WINDOW=10
ADMIN_RATE_LIMIT_PER_WINDOW=30
