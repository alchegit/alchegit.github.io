# Copy this file to .env on the external server.
# Never commit .env. The repository .gitignore blocks it.

WEBTOON_BACKEND=oracle

# Oracle API mode
ORACLE_API_BASE_URL=https://your-api.example.com
WEBTOON_WORKER_TOKEN=replace_with_long_random_worker_token

# Legacy Supabase mode
SUPABASE_URL=https://anjbgbqkeukllsdxgckv.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_with_server_only_service_role_key

# manual-prompt writes ChatGPT Pro prompt files into ./outbox without API billing.
# Future modes can be added later, for example openai-image.
WORKER_MODE=manual-prompt

POLL_INTERVAL_MS=8000
BATCH_SIZE=1
OUTBOX_DIR=./outbox
